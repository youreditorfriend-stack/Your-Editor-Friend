VITE_ADMIN_PASSWORD=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# AI assistant — server-side only, NEVER prefixed with VITE_ (that would ship
# it to the browser). Set these in Vercel → Project → Settings → Environment.
#
# Gemini is the DEFAULT provider (text + image/vision). OpenAI is used only for
# video / complex creative reasoning. Routing is env-driven — the app never
# hardcodes a provider.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional per-task provider overrides (defaults shown). Add e.g. "claude"
# here once a ClaudeProvider is registered — no other change needed.
AI_PROVIDER_TEXT=gemini
AI_PROVIDER_VISION=gemini
AI_PROVIDER_VIDEO=openai