{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/products/:id", "destination": "/api/item-page?kind=product&id=:id" },
    { "source": "/courses/:id",  "destination": "/api/item-page?kind=course&id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
